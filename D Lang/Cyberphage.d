/* Create a Complete Robot instruction Set, a Single bank instruction Set, or a Random instruction */
string Create_Bot_Code(int mode){
// Mode 1: Complete Robot code with random banks and instructions
// Mode 2: Single Robot bank with random instructions
// Mode 3: Single Robot random instruction

// Using array indexing with uniform distribution
string result = "BANK " ~ RndBankname(10, 20) ~ "\n";

// Define the minLength and maxLength
uint minLength = 10;
uint maxLength = uniform(minLength,  20);

// Get a random Code length between minLength and maxLength
uint rndCodeLength = uniform(minLength, maxLength + 1);

// Define the minbank and maxbank
uint minbank = 1;
uint maxbank = uniform(1,  41);

switch (mode){
    case 1:
		foreach (i; 0 .. rndCodeLength){
			result = result ~ Op_Instr(uniform(0, 13),1) ~ "\n";
		}
		break;
	case 2:
		foreach (i; 0 .. rndCodeLength){
		result = result ~ Op_Instr(uniform(0, 12),1) ~ "\n";
		}
		break;
	case 3:	
    // Removes the starting Bank.
		result = "";
	
		foreach (i; 0 .. rndCodeLength){
			result = result ~ Op_Instr(uniform(0, 12),1) ~ "\n";
			}
		break;
    default:
		writeln("Invalid mode");
    break;
}

return result;
}

/* Create a Single bank instruction Set of a defined length */
string Create_Bot_Code(int mode, int Num_Instructions){
// Mode 1: Single Robot with defined number of instructions or banks



// Mode 2: Single Robot bank with defined number of instructions

// Using array indexing with uniform distribution
string result = "BANK " ~ RndBankname(10, 20) ~ "\n";

if (1 == mode){
	foreach (i; 0 .. Num_Instructions) {result = result ~ Op_Instr(uniform(0, 13),1) ~ "\n";}
}
else if  (2 == mode){
	foreach (i; 0 .. Num_Instructions) {result = result ~ Op_Instr(uniform(0, 12),1) ~ "\n";}
}

return result;
}

// Creates a random set of characters
string RndBankname(uint minLength, uint maxLength){
	// Get a random length between minLength and maxLength
    uint length = uniform(minLength, maxLength + 1);
    
    // Define the character set (e.g., letters and digits)
    immutable char[] charset = letters ~ digits ~ "#" ~ "!" ~ "@";
    
    // Generate the string by sampling from the charset
    // Using array indexing with uniform distribution
    char[] result; result.length = length;
    foreach (i; 0 .. length) {result[i] = charset[uniform(0, charset.length)]; }
    
    return result.idup;
}

